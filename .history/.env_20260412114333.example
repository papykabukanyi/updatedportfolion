# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is listed in .gitignore.

# Gmail SMTP credentials (use a Gmail App Password, NOT your account password)
# How to generate: https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# The recipient address for contact form messages (usually same as GMAIL_USER)
CONTACT_RECIPIENT=your_gmail_address@gmail.com

# The public URL of your deployed site (used for SEO canonical URLs, sitemap, OG meta)
NEXT_PUBLIC_SITE_URL=https://your-app.up.railway.app

# Optional: set this on Railway / production to your public domain
NEXT_PUBLIC_SITE_URL=https://your-app.up.railway.app
